# Copy this file to your platform root (the directory that contains your
# content packages) as `.env`, then fill in the real values LOCALLY.
# Never commit .env, paste the secret into chat, or put it in a content package.
#
# The WeChat Official Account must expose the material and draft APIs, and the
# machine's public egress IP must be allowed in the account's developer config.
WECHAT_APP_ID=replace_me
WECHAT_APP_SECRET=replace_me
